{
  "name": "@alma-oss/spirit-docsite",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/docsite/src",
  "projectType": "application",
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/.next"],
      "dependsOn": ["^build"],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"]
    }
  },
  "implicitDependencies": [
    "@alma-oss/spirit-design-tokens",
    "@alma-oss/spirit-icons",
    "@alma-oss/spirit-web",
    "@alma-oss/spirit-web-react"
  ]
}
