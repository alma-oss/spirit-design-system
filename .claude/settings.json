{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "plan",
    "allow": [
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(echo:*)",
      "Bash(pwd)",
      "Bash(which:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(diff:*)",
      "Bash(stat:*)",
      "Bash(jq:*)",
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git branch:*)",
      "Bash(git show:*)",
      "Bash(git remote:*)",
      "Bash(git stash:*)",
      "Bash(git tag:*)",
      "Bash(gh pr:*)",
      "Bash(gh repo:*)",
      "Bash(yarn *)",
      "Bash(make *)"
    ],
    "deny": [
      "Bash(git push --force:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean -fd:*)",
      "Bash(git branch -D:*)",
      "Bash(git filter-branch:*)",
      "Bash(git gc:*)",
      "Bash(make version)",
      "Bash(* publish:*)",
      "Read(~/.ssh/*)",
      "Read(.env*)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  },
  "enabledMcpjsonServers": ["chrome-devtools", "context7", "figma", "github", "mcp-atlassian"]
}
