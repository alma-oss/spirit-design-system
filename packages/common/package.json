{
  "name": "@alma-oss/spirit-common",
  "version": "0.5.4",
  "description": "Common code and scripts for Spirit Design System",
  "license": "MIT",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./constants": {
      "types": "./src/constants/index.ts",
      "default": "./src/constants/index.ts"
    },
    "./constants/servers": {
      "types": "./src/constants/servers.ts",
      "default": "./src/constants/servers.ts"
    },
    "./constants/environments": {
      "types": "./src/constants/environments.ts",
      "default": "./src/constants/environments.ts"
    },
    "./utilities": {
      "types": "./src/utilities/index.ts",
      "default": "./src/utilities/index.ts"
    },
    "./utilities/url": {
      "types": "./src/utilities/url.ts",
      "default": "./src/utilities/url.ts"
    }
  },
  "keywords": [
    "spirit",
    "common",
    "design-system",
    "shared"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alma-oss/spirit-design-system.git",
    "directory": "packages/common"
  },
  "scripts": {
    "lint": "eslint ./",
    "lint:fix": "yarn lint --fix",
    "test": "npm-run-all --serial lint types test:unit:coverage",
    "test:unit": "jest",
    "test:unit:watch": "yarn test:unit --watchAll",
    "test:unit:coverage": "yarn test:unit --coverage",
    "types": "tsc"
  },
  "devDependencies": {
    "@eslint/compat": "catalog:lint",
    "@eslint/eslintrc": "catalog:lint",
    "@types/jest": "catalog:types",
    "@types/node": "catalog:types",
    "eslint": "catalog:lint",
    "eslint-config-spirit": "workspace:^",
    "jest": "catalog:test",
    "npm-run-all2": "catalog:script",
    "ts-node": "catalog:script",
    "typescript": "catalog:types"
  }
}
