{
  "name": "@alma-oss/spirit-icons",
  "version": "3.0.4",
  "description": "Icons for Spirit Design System",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/alma-oss/spirit-design-system.git",
    "directory": "packages/icons"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./icons": {
      "types": "./dist/icons.d.ts",
      "import": "./dist/icons.js",
      "require": "./dist/icons.cjs",
      "default": "./dist/icons.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "import": "./dist/react/index.js",
      "require": "./dist/react/index.cjs",
      "default": "./dist/react/index.js"
    },
    "./react/*": {
      "types": "./dist/react/*.d.ts",
      "import": "./dist/react/*.js",
      "require": "./dist/react/*.cjs",
      "default": "./dist/react/*.js"
    },
    "./svg/*": "./dist/svg/*.svg"
  },
  "scripts": {
    "build:clean": "shx rm -rf dist .icons-tmp",
    "build:vite": "vite build",
    "build:verify": "tsx ./scripts/verifyBuild.ts",
    "build": "npm-run-all --serial build:clean build:vite build:verify",
    "dev": "vite build --watch",
    "types": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@alma-oss/vite-plugin-spirit-icons": "workspace:^",
    "@types/node": "catalog:types",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "@vitejs/plugin-react": "catalog:build",
    "npm-run-all2": "catalog:script",
    "shx": "catalog:script",
    "svg2react-icon": "catalog:script",
    "tsx": "catalog:script",
    "typescript": "catalog:types",
    "vite": "catalog:build",
    "vite-plugin-dts": "catalog:build",
    "vite-plugin-externalize-deps": "catalog:build"
  }
}
