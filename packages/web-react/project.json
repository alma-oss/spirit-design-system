{
  "name": "@alma-oss/spirit-web-react",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/web-react/src",
  "projectType": "library",
  "targets": {
    "build": {
      "outputs": ["{projectRoot}/dist"],
      "cache": true,
      "dependsOn": ["^build"]
    },
    "types": {
      "cache": true,
      "dependsOn": ["@alma-oss/spirit-icons:build", "@alma-oss/spirit-design-tokens:build"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint ./",
        "cwd": "{projectRoot}"
      },
      "cache": true,
      "dependsOn": ["@alma-oss/spirit-icons:build", "@alma-oss/spirit-design-tokens:build"]
    },
    "lint-fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint ./ --fix",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["@alma-oss/spirit-icons:build", "@alma-oss/spirit-design-tokens:build"]
    }
  }
}
